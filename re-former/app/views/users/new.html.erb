<form accept-charset="UTF-8" action="/users" method="post">
  <label for="username">Username</label><br>
  <input id="username" name="user[username]" type="text"><br><br>
  <label for="email">Email</label><br>
  <input id="email" name="user[email]" type="text"><br><br>
  <label for="password">Password</label><br>
  <input id="password" name="user[password]" type="password"><br><br>
  <input name="commit" type="submit" value="Create User">
</form>